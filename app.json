{
  "expo": {
    "name": "Sinne",
    "slug": "sinne",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sinne",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sinne.app",
      "deploymentTarget": "16.4"
    },
    "android": {
      "package": "com.sinne.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F7F3EE"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
